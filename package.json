  "keywords": ["mcp", "model-context-protocol", "vision", "openai", "vl"],
  "repository": { "type": "git", "url": "git+https://github.com/winton979/vision-mcp.git" },
  "homepage": "https://github.com/winton979/vision-mcp#readme",
