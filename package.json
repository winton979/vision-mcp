  "license": "MIT",
  "dependencies": { "@modelcontextprotocol/sdk": "^1.0.4" },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
